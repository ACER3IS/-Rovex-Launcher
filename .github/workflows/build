name: Windows Launcher Build

on:
  push:
    branches: [ master ]

jobs:
  build-windows:
    runs-on: windows-2022

    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up Node.js
        uses: actions/setup-node@v3
        with:
          node-version: 20

      - name: Install dependencies
        run: npm ci

      - name: Build launcher
        run: npm run build

      - name: Build Windows EXE
        run: |
          npm install -g pkg
          mkdir -p release
          pkg . --targets node20-win-x64 --output release/launcher.exe

      - name: Upload EXE artifact
        uses: actions/upload-artifact@v4
        with:
          name: RovexLauncher-Windows
          path: release/launcher.exe
